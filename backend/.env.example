PORT=5002
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://sunny1234:sunny1234@atlascluster.d98myub.mongodb.net/google-prep-tracker?retryWrites=true&w=majority

# Auth secrets — REQUIRED in production; use long random strings
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<required-change-me>
SESSION_SECRET=<required-change-me>

# URLs
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5002

# OAuth — fill in to enable Google/GitHub social login (optional)
# GitHub: https://github.com/settings/developers → New OAuth App
#   Callback URL: <API_URL>/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google: https://console.cloud.google.com/apis/credentials → Create Credentials
#   Callback URL: <API_URL>/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
